<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@color/bg_keyboard">

    <!-- Suggestion Bar -->
    <com.brruham.t9ime.SuggestionBarView
        android:id="@+id/suggestion_bar"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:background="@color/bg_suggestion" />

    <!-- Mode Indicator Strip -->
    <TextView
        android:id="@+id/mode_indicator"
        android:layout_width="match_parent"
        android:layout_height="18dp"
        android:text="@string/mode_predictive"
        android:textColor="@color/mode_indicator"
        android:textSize="9sp"
        android:fontFamily="monospace"
        android:gravity="center"
        android:letterSpacing="0.15"
        android:background="@color/bg_keyboard" />

    <!-- 9-Key Grid -->
    <com.brruham.t9ime.T9KeyboardView
        android:id="@+id/keyboard_view"
        android:layout_width="match_parent"
        android:layout_height="280dp" />

</LinearLayout>
